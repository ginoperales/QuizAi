rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users Collection
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      allow list: if request.auth != null; // Needed to check first user on signup and list for admin
    }

    // Quizzes Collection
    match /quizzes/{quizId} {
      allow read: if true; // Anyone can view quizzes, whether logged in or not
      allow create: if request.auth != null;
      allow update: if request.auth != null; // Allow logged-in users to update completers
      allow delete: if request.auth != null && (resource.data.creatorUid == request.auth.uid || isAdmin());
    }

    // Attempts Collection
    match /attempts/{attemptId} {
      allow read: if request.auth != null && (resource.data.userUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (request.resource.data.userUid == request.auth.uid);
      allow delete: if isAdmin();
      allow list: if request.auth != null && isAdmin(); // Only admins can list all attempts
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && (resource.data.recipientUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
    }

    // Activity Logs Collection
    match /activity_logs/{logId} {
      allow read, list: if request.auth != null && isAdmin();
      allow create: if true; // Allow anyone/guests to log their activities
      allow update, delete: if false; // Logs cannot be modified or deleted by anyone!
    }

    // Quiz Reports Collection
    match /quiz_reports/{reportId} {
      allow read, list: if request.auth != null && isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // Question Feedback Collection
    match /question_feedback/{feedbackId} {
      allow read, list: if request.auth != null && (resource.data.creatorUid == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }
  }
}
